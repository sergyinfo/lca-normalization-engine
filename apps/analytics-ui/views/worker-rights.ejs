<%- include('partials/header', { title, active }) %>

<section class="persona-hero">
  <h1>Worker Rights / NGO</h1>
  <p>The labor-protection angle: where offered wages cluster at the prevailing-wage floor, which sponsors withdraw cases at high rates, and which states have lopsided employer concentration.</p>
  <ul class="questions">
    <li>Which SOCs cluster wages closest to the legal prevailing-wage floor?</li>
    <li>Which employers have the highest withdrawal rates (≥100 filings)?</li>
    <li>Which states are dominated by 1–3 employers (concentration risk)?</li>
  </ul>
</section>

<div class="panel-grid">
  <%- include('partials/panel', {
    title: 'Wage premium over prevailing wage (lowest P50 ratios)',
    subtitle: 'Offered wage ÷ prevailing wage. A median ratio of 1.00 means the typical worker is paid exactly the legal minimum.',
    tag: 'wage floor',
    chartId: 'chartPremium',
    body: null,
  }) %>
</div>

<section class="panel" style="margin-top:18px;">
  <header class="panel-head"><h2>SOCs with wages clustered nearest the legal floor</h2><span class="tag">compliance</span></header>
  <p class="panel-sub muted small">"Near-floor %" = filings where offered wage is 0.98–1.02× prevailing wage. High = workers paid the legal minimum; not necessarily illegal but a signal for downstream wage-theft research.</p>
  <table class="data">
    <thead><tr><th>SOC</th><th>Title</th><th class="num">N</th><th class="num">P25 ratio</th><th class="num">Median ratio</th><th class="num">P75 ratio</th><th class="num">Near-floor %</th></tr></thead>
    <tbody>
    <% premium.forEach(p => { %>
      <tr>
        <td><strong><%= p.soc_code %></strong></td>
        <td><%= (p.soc_title || '—').slice(0, 60) %></td>
        <td class="num"><%= Number(p.n).toLocaleString() %></td>
        <td class="num"><%= Number(p.p25_ratio).toFixed(3) %></td>
        <td class="num"><strong><%= Number(p.p50_ratio).toFixed(3) %></strong></td>
        <td class="num"><%= Number(p.p75_ratio).toFixed(3) %></td>
        <td class="num"><%= p.near_floor_pct ?? '—' %>%</td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</section>

<section class="panel" style="margin-top:18px;">
  <header class="panel-head"><h2>State employer concentration (top 3 per state)</h2><span class="tag">concentration</span></header>
  <p class="panel-sub muted small">Each row = one of the three highest-volume sponsors in that state. Share % is that sponsor's filings as a fraction of the state's total H-1B filings.</p>
  <table class="data">
    <thead><tr><th>State</th><th>Canonical employer</th><th class="num">Sponsor filings</th><th class="num">State total</th><th class="num">Share %</th></tr></thead>
    <tbody>
    <% concentration.forEach(c => { %>
      <tr>
        <td><strong><%= c.state %></strong></td>
        <td><%= c.canonical_name %></td>
        <td class="num"><%= Number(c.filings).toLocaleString() %></td>
        <td class="num"><%= Number(c.state_filings).toLocaleString() %></td>
        <td class="num"><strong><%= c.share_pct ?? '—' %>%</strong></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</section>

<section class="panel" style="margin-top:18px;">
  <header class="panel-head"><h2>Highest-withdrawal sponsors (≥100 filings)</h2><span class="tag">churn</span></header>
  <p class="panel-sub muted small">Sorted by combined withdrawal + cert-withdrawn rate. High rates can indicate revolving-door employment, project cancellations, or visa-status churn.</p>
  <table class="data">
    <thead><tr><th>#</th><th>Canonical employer</th><th>State</th><th class="num">Filings</th><th class="num">Cert %</th><th class="num">WD %</th><th class="num">Cert-WD %</th><th class="num">Denied %</th></tr></thead>
    <tbody>
    <% churn.forEach((c, i) => { %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= c.canonical_name %></td>
        <td><%= c.employer_state || '—' %></td>
        <td class="num"><%= Number(c.filings).toLocaleString() %></td>
        <td class="num"><%= c.certified_pct ?? '—' %></td>
        <td class="num"><strong><%= c.withdrawn_pct ?? '—' %></strong></td>
        <td class="num"><strong><%= c.cert_withdrawn_pct ?? '—' %></strong></td>
        <td class="num"><%= c.denied_pct ?? '—' %></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</section>

<script>
const premiumLabels = <%- JSON.stringify(premium.map(p => (p.soc_title || p.soc_code).slice(0, 28))) %>;
const premiumP25 = <%- JSON.stringify(premium.map(p => Number(p.p25_ratio))) %>;
const premiumP50 = <%- JSON.stringify(premium.map(p => Number(p.p50_ratio))) %>;
const premiumP75 = <%- JSON.stringify(premium.map(p => Number(p.p75_ratio))) %>;
new Chart(document.getElementById('chartPremium'), {
  type: 'bar',
  data: { labels: premiumLabels, datasets: [
    { label: 'P25', data: premiumP25, backgroundColor: 'rgba(234,88,12,0.35)' },
    { label: 'Median', data: premiumP50, backgroundColor: '#ea580c' },
    { label: 'P75', data: premiumP75, backgroundColor: 'rgba(194,65,12,0.85)' },
  ] },
  options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { x: { beginAtZero: true, ticks: { callback: v => v.toFixed(2) + 'x' } } } },
});
</script>

<%- include('partials/footer') %>
