{
  "name": "cli-tool",
  "version": "0.1.0",
  "description": "CLI for DB initialisation and seeding the BullMQ task tree from a local LCA archive",
  "type": "module",
  "main": "./index.js",
  "bin": {
    "lca-cli": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "db:init": "node index.js db:init",
    "db:status": "node index.js db:status",
    "seed": "node index.js seed",
    "test": "node --test",
    "lint": "eslint ."
  },
  "dependencies": {
    "@lca/db-lib": "workspace:*",
    "bullmq": "^5.12.0",
    "ioredis": "^5.3.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "pino": "^9.2.0",
    "glob": "^11.0.0"
  }
}
