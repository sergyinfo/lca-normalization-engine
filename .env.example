# PostgreSQL
DATABASE_URL=postgresql://lca_user:lca_pass@localhost:5432/lca_db
POSTGRES_USER=lca_user
POSTGRES_PASSWORD=lca_pass
POSTGRES_DB=lca_db
# First year partition created for lca_records (default 2020 = the data floor we
# ingest). A DEFAULT partition (lca_records_overflow) catches any out-of-range
# year. Lowering this adds older-year partitions on the next db:init — but drain
# any matching rows out of the DEFAULT partition first (see packages/db-lib).
LCA_PARTITION_START_YEAR=2020

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Harvester
DOL_BASE_URL=https://www.dol.gov/agencies/eta/foreign-labor/performance
HARVESTER_POLL_INTERVAL_MS=3600000
# Scope: only H-1B LCA Disclosure files at/above the year floor are taken.
# Capture group 1 of HARVEST_FILE_PATTERN must be the filing year.
HARVEST_START_YEAR=2020
# HARVEST_FILE_PATTERN=LCA_Disclosure_Data_FY(20\d{2})
# HARVEST_ONCE=1            # run a single scoped poll then exit (the burst uses this)
# HARVEST_USER_AGENT=...    # override the browser UA (the DOL page is bot-gated)
# LOCAL_FILES_DIR=./data    # where the harvester downloads files (mounted into the ingestor)

# Ingestor
INGESTOR_CONCURRENCY=4
INGESTOR_BATCH_SIZE=5000

# NLP Worker
NLP_WORKER_CONCURRENCY=2
NLP_STAGE2_MODEL=sentence-transformers/all-MiniLM-L6-v2
NLP_STAGE2_THRESHOLD=0.7
NLP_DEVICE=cpu
# Post-batch Layer-3 embedding sweep (set NLP_AUTO_EMBED=0 to disable).
NLP_AUTO_EMBED=1
NLP_AUTO_EMBED_MAX_ROWS=1000
# Entity-resolution thresholds: Layer 2 pg_trgm similarity + Layer 3 pgvector cosine distance.
NLP_TRGM_THRESHOLD=0.85
NLP_VECTOR_MAX_DIST=0.15

# NLP — alias bootstrap + per-employer consensus mining thresholds
BOOTSTRAP_MIN_HITS=5
BOOTSTRAP_MIN_EMPLOYERS=2
BOOTSTRAP_MIN_AGREEMENT=0.8
EMP_CONSENSUS_MIN_HITS=5
EMP_CONSENSUS_MIN_AGREEMENT=0.8

# NLP — Stage 3 LLM reclassify (low-confidence residual). Backend = Ollama
# (local) or Anthropic (cloud). LLM_MODEL default tracks the backend:
# "llama3.1:8b" for Ollama, "claude-haiku-4-5-20251001" for Anthropic.
LLM_SHORT_TITLE_THRESHOLD=12
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.1:8b
# Only needed when using the Anthropic backend for Stage 3:
ANTHROPIC_API_KEY=

# CLI Tool
DEFAULT_FILES_DIR=./data/lca-archive
# Host→container path mapping used by the ingestor seed step.
CONTAINER_MOUNT_DIR=/data

# Logging (all Node services)
LOG_LEVEL=info

# Operator HITL UI
# Set OPERATOR_PASSWORD to any non-empty value before starting the operator-ui service.
# SESSION_SECRET must be at least 32 characters; generate with `openssl rand -hex 32`.
OPERATOR_PASSWORD=change-me-please
SESSION_SECRET=change-me-to-a-32-plus-char-random-string-please
OPERATOR_UI_HOST=0.0.0.0
OPERATOR_UI_PORT=8080

# Internal Analytics UI (apps/analytics-ui)
ANALYTICS_UI_HOST=0.0.0.0
ANALYTICS_UI_PORT=8081

# Public Analytics Website (apps/analytics-web)
# Branding + canonical URL (NEXT_PUBLIC_* are inlined at build time).
NEXT_PUBLIC_SITE_NAME=H1B Report
NEXT_PUBLIC_SITE_URL=https://h1b.report
NEXT_PUBLIC_FEATURE_API=false
NEXT_PUBLIC_GTM_ID=
# SQLite snapshot + API-keys DB paths (Docker/Lambda override these).
LCA_SQLITE_DIR=./apps/analytics-web/data
LCA_SQLITE_PATH=./apps/analytics-web/data/lca.db
LCA_KEYS_DB_PATH=./apps/analytics-web/data/keys.db
# Top-N entity counts baked into the snapshot by build:sqlite.
TOP_EMPLOYERS=200
TOP_OCCUPATIONS=100
TOP_STATES=60
TOP_SECTORS=30
# LLM SEO-content generation (build:summaries) — page summary + meta title/description.
# NOTE: build:summaries runs with cwd apps/analytics-web, so it reads
# apps/analytics-web/.env (gitignored). The burst EC2 reads LLM_API_KEY from
# Secrets Manager (lca/llm-api-key). Provider: stub|anthropic|openai|local.
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_SUMMARY_MODEL=claude-haiku-4-5   # model for summary + meta (Haiku is plenty; swap to claude-sonnet-4-6 for more polish)
LLM_MODE=batch                       # batch = Message Batches API (50% off, whole-site); sync = one page at a time
LLM_LIMIT=0                          # >0 caps how many changed entities to generate this run (smoke testing)
LLM_BASE_URL=http://localhost:8000/v1
LLM_CONCURRENCY=6
# Monetisation (renders transparent placeholders when unset).
ADSENSE_CLIENT_ID=
ADSENSE_SLOTS=

# Cloudflare (landing page deploy + cache purge)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ---------------------------------------------------------------------------
# AWS deployment (infra/aws CDK + migrate-from-local.sh / sync-static.sh)
# ---------------------------------------------------------------------------
AWS_PROFILE=
AWS_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-east-1
LCA_ENVIRONMENT=prod
# Private repo the burst EC2 clones (token lives in Secrets Manager: lca/github-token).
GITHUB_REPO=sergyinfo/lca-normalization-engine
# Budgets stack (LcaBudgetsStack) — alert email + USD thresholds.
LCA_BILLING_EMAIL=
LCA_MONTHLY_BUDGET_USD=20
LCA_BURST_BUDGET_USD=50
LCA_ANNUAL_BUDGET_USD=150
LCA_COMPONENT_BUDGET_USD=10
LCA_ANOMALY_THRESHOLD_USD=5
# NOTE: the serving domain/cert are CDK *context*, not env vars — pass on deploy:
#   cdk deploy LcaServeStack -c siteCertificateArn=arn:aws:acm:us-east-1:…:certificate/… \
#     -c siteDomains=dev.h1b.report -c siteUrl=https://dev.h1b.report
